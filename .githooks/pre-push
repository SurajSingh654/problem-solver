#!/usr/bin/env bash
# Pre-push gate — every check that can catch a bug before code leaves
# the local machine. Aborts the push on any failure.
#
# Activate this hook (run once per clone):
#     git config core.hooksPath .githooks
#
# Skip in an emergency with `git push --no-verify` (use sparingly).

set -e

ROOT="$(git rev-parse --show-toplevel)"
START_TIME=$(date +%s)

cyan()  { printf "\033[36m%s\033[0m\n" "$1"; }
red()   { printf "\033[31m%s\033[0m\n" "$1"; }
green() { printf "\033[32m%s\033[0m\n" "$1"; }
gray()  { printf "\033[90m%s\033[0m\n" "$1"; }

run_in() {
    local dir="$1"
    local label="$2"
    shift 2
    cyan "▶ ${label}"
    if ! ( cd "${ROOT}/${dir}" && "$@" ); then
        red "✘ ${label} failed — push aborted"
        exit 1
    fi
}

# ── SERVER ────────────────────────────────────────────────────
if [ -d "${ROOT}/server" ] && [ -f "${ROOT}/server/package.json" ]; then
    run_in server "server: lint (strict)" npm run lint
    run_in server "server: tests"          npm run test

    # Vulnerability gate — fails on HIGH or CRITICAL CVEs in deps.
    # Moderates print as warnings but do not block. (MCP-5.)
    # Bypass via --no-verify only if the upstream fix is in flight + tracked.
    run_in server "server: npm audit (high+)" npm audit --audit-level=high

    # Prisma migration drift — fails if there are pending migrations
    # the local clone hasn't run, OR if schema.prisma is ahead of the
    # migration history. Either case would break a deploy.
    cyan "▶ server: prisma migrate status"
    if ! ( cd "${ROOT}/server" && npx --no-install prisma migrate status >/dev/null 2>&1 ); then
        # Run again without -q so the user sees the actual diff.
        ( cd "${ROOT}/server" && npx --no-install prisma migrate status ) || true
        red "✘ server: prisma migrate status failed — pending or drifted migrations"
        red "   Either run \`npm run db:migrate\` locally or commit the missing migration."
        exit 1
    fi
fi

# ── CLIENT ────────────────────────────────────────────────────
if [ -d "${ROOT}/client" ] && [ -f "${ROOT}/client/package.json" ]; then
    run_in client "client: lint (strict)" npm run lint

    # Vulnerability gate — fails on HIGH or CRITICAL CVEs in deps. (MCP-5.)
    run_in client "client: npm audit (high+)" npm audit --audit-level=high

    # Build verification — catches:
    #   • broken imports / circular dependencies
    #   • Vite plugin errors
    #   • bundle-blocking syntax errors that lint missed
    #   • the recent class of bug where VITE_FEATURE_* didn't reach
    #     the bundle (any future regression with env-var wiring is
    #     caught here when the build's output is inspected by humans).
    # ~30s overhead per push; bypass with --no-verify in true emergencies.
    run_in client "client: vite build"     npm run build
fi

DURATION=$(($(date +%s) - START_TIME))
green "✔ All pre-push checks passed (${DURATION}s)"
gray  "  Skip with --no-verify in genuine emergencies."
