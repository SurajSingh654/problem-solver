# ── API ──────────────────────────────────────────────
# Dev: leave unset — Vite proxies /api → http://localhost:5000.
# Prod: set to the deployed server URL ending in /api, e.g.
# VITE_API_URL=https://probsolver-api.up.railway.app/api

# ── Feature flags ────────────────────────────────────
# Each VITE_* flag must ALSO be declared as an ARG/ENV pair in
# client/Dockerfile, otherwise Railway's runtime env never reaches
# `vite build` and the var becomes undefined in the bundle.

# Team Teaching Sessions
# VITE_FEATURE_TEACHING_SESSIONS=true

# Personal Notes + SM-2 Flashcards
# VITE_FEATURE_NOTES_ENABLED=true

# Tabbed Submit form (BruteForce + Optimized + Alternative tabs in
# SubmitSolutionPage, matching EditSolutionPage's structure). Default
# `true` — set to `false` to revert to the legacy flat single-textarea
# Submit form. Useful as a kill-switch if the new form misbehaves in prod.
# VITE_FEATURE_SUBMIT_TABBED=true

# Coding Pattern Mastery v2 — replaces "X of 25 patterns" coverage card
# with the per-pattern Owned/Solid/Working/Touched/Untouched matrix and
# enables strict tier mastery gates (server flag: FEATURE_PATTERN_MASTERY_V2).
# Both server + client flags should flip together.
# VITE_FEATURE_PATTERN_MASTERY_V2=true

# Solution Depth v2 — replaces length-threshold scoring with a per-solution
# 5-state machine (None / Documented / Explained / Defended / Owned), reads
# follow-up answers + recallText for probe-passing + retrieval evidence.
# Renders an inline stacked bar in the D2 dim card. Server flag:
# FEATURE_SOLUTION_DEPTH_V2. Both server + client flags flip together.
# VITE_FEATURE_SOLUTION_DEPTH_V2=true

# Communication v2 — replaces the legacy if-else cascade with source-tier
# ceiling scoring (written-only 55, +live 80, +peer 100). Fixes the
# score-outside-CI bug from the original report. Renders a source-quality
# chip in the D3 dim card. Server flag: FEATURE_COMMUNICATION_V2. Both
# server + client flags flip together.
# VITE_FEATURE_COMMUNICATION_V2=true

# Optimization v2 — replaces the legacy length-threshold + correctness-
# multiplier formula with a per-solution 5-state machine (None /
# Documented / Optimized / Trade-off / Owned). Reads AI complexityCheck
# + bruteForceMeta for trade-off articulation. Renders an inline 5-state
# stacked bar in the D4 dim card. Server flag: FEATURE_OPTIMIZATION_V2.
# Both server + client flags flip together.
# VITE_FEATURE_OPTIMIZATION_V2=true

# Pressure Performance v2 — replaces the legacy quiz-dominant blend
# with source-tier ceiling scoring (quiz-proxy 40 / live mocks 80 /
# stable mocks 100). Subject filter excludes Photography/Hindi/Physics
# quizzes; difficulty-weighted (HARD/MEDIUM/EASY). Renders a source-
# quality chip in the D5 dim card. Server flag: FEATURE_PRESSURE_PERFORMANCE_V2.
# Both server + client flags flip together.
# VITE_FEATURE_PRESSURE_PERFORMANCE_V2=true

# Knowledge Retention v2 — strictly additive (FSRS scoring preserved).
# Adds tier mastery gates (sample size + leech rate) and surfaces leech
# count (lapseCount >= 8) inline in the D6 dim card. Server flag:
# FEATURE_RETENTION_V2. Both server + client flags flip together.
# VITE_FEATURE_RETENTION_V2=true

# Teaching Contributions v2 — replaces the gameable v1 formula (30%
# volume × 50% avg-rating × 20% peer-learned) with a source-tier ceiling
# (draft-only 30 / peer-validated 70 / stable-peer-cohort 100), mirroring
# D3/D5. Adds tier mastery gates (sessions / ratings / score / flag-rate)
# and renders a source-quality chip + flagged-sessions warning in the D7
# dim card. Server flag: FEATURE_TEACHING_CONTRIBUTIONS_V2. Both server +
# client flags flip together.
# VITE_FEATURE_TEACHING_CONTRIBUTIONS_V2=true

# Design Aptitude (D8) — NEW dimension. Reads DesignSession evaluations
# (10-dim AI rating per designType, scenario validation, INTERVIEW-mode
# pairing) which were previously dark to the readiness report. Opt-in
# like D7 — only counts when user has ≥1 completed design session with
# evaluation. Source-tier ceiling: draft-only 30 / scenario-tested 70 /
# interviewer-paired 100. Renders source-quality chip in the D8 dim card.
# Server flag: FEATURE_DESIGN_APTITUDE. Both server + client flags flip
# together.
# VITE_FEATURE_DESIGN_APTITUDE=true

# Behavioral Performance (D9) — NEW dimension. Reads InterviewSession
# behavioralSignals (clarifying questions, narration, edge cases, hints),
# preSessionConfidence (Kruger-Dunning calibration), interviewStyle
# (8 culture styles), and HR Problem solutions. Distinct from D5
# Pressure Performance — same source data but different signals. Opt-in
# like D7/D8 — activates with ≥1 mock OR ≥3 HR solutions. Source-tier:
# draft-only 30 / mock-validated 70 / diversified 100. Renders source-
# quality chip + calibration-delta warning in the D9 dim card. Server
# flag: FEATURE_BEHAVIORAL_PERFORMANCE. Both server + client flags flip
# together.
# VITE_FEATURE_BEHAVIORAL_PERFORMANCE=true

# Verification & Meta-cognition (D10) — NEW BASELINE dimension (not
# opt-in). Extracts signals previously buried in D2/D4/D9 as a coherent
# meta-skill: calibrated self-assessment + complexity verification +
# pattern accuracy + probe defense + edge-case independence. Activates
# with ≥5 AI-reviewed coding solutions. Source-tier: proxy-only 40 /
# multi-signal 75 / strong-signal 100. Renders source-quality chip +
# calibration-gap + wrong-pattern warnings in the D10 dim card. Server
# flag: FEATURE_VERIFICATION_METACOGNITION. Both server + client flags
# flip together.
# VITE_FEATURE_VERIFICATION_METACOGNITION=true

# MCP token management UI (Phase MCP-4-UI). Enables the API Access section
# on /settings — users can issue/list/revoke their own MCP tokens for
# `claude mcp add --header`. Server flag: FEATURE_MCP_ENABLED. Both server +
# client flags should flip together.
# VITE_FEATURE_MCP_ENABLED=true

# Public URL of the MCP Streamable HTTP endpoint, used to build the
# `claude mcp add` snippet shown after token creation. Path component is
# usually /mcp. Example: https://probsolver-api.up.railway.app/mcp
# VITE_MCP_URL=https://your-deployment.example.com/mcp
