# ── API ──────────────────────────────────────────────
# Dev: leave unset — Vite proxies /api → http://localhost:5000.
# Prod: set to the deployed server URL ending in /api, e.g.
# VITE_API_URL=https://probsolver-api.up.railway.app/api

# ── Feature flags ────────────────────────────────────
# Each VITE_* flag must ALSO be declared as an ARG/ENV pair in
# client/Dockerfile, otherwise Railway's runtime env never reaches
# `vite build` and the var becomes undefined in the bundle.

# Team Teaching Sessions
# VITE_FEATURE_TEACHING_SESSIONS=true

# Personal Notes + SM-2 Flashcards
# VITE_FEATURE_NOTES_ENABLED=true
