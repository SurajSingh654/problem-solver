# ── API ──────────────────────────────────────────────
# Dev: leave unset — Vite proxies /api → http://localhost:5000.
# Prod: set to the deployed server URL ending in /api, e.g.
# VITE_API_URL=https://probsolver-api.up.railway.app/api

# ── Feature flags ────────────────────────────────────
# Each VITE_* flag must ALSO be declared as an ARG/ENV pair in
# client/Dockerfile, otherwise Railway's runtime env never reaches
# `vite build` and the var becomes undefined in the bundle.

# Team Teaching Sessions
# VITE_FEATURE_TEACHING_SESSIONS=true

# Personal Notes + SM-2 Flashcards
# VITE_FEATURE_NOTES_ENABLED=true

# Tabbed Submit form (BruteForce + Optimized + Alternative tabs in
# SubmitSolutionPage, matching EditSolutionPage's structure). Default
# `true` — set to `false` to revert to the legacy flat single-textarea
# Submit form. Useful as a kill-switch if the new form misbehaves in prod.
# VITE_FEATURE_SUBMIT_TABBED=true

# Coding Pattern Mastery v2 — replaces "X of 25 patterns" coverage card
# with the per-pattern Owned/Solid/Working/Touched/Untouched matrix and
# enables strict tier mastery gates (server flag: FEATURE_PATTERN_MASTERY_V2).
# Both server + client flags should flip together.
# VITE_FEATURE_PATTERN_MASTERY_V2=true
