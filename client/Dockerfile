FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .

# Accept build args and set as env vars for Vite
ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL
ARG VITE_FEATURE_TEACHING_SESSIONS
ENV VITE_FEATURE_TEACHING_SESSIONS=$VITE_FEATURE_TEACHING_SESSIONS
ARG VITE_FEATURE_NOTES_ENABLED
ENV VITE_FEATURE_NOTES_ENABLED=$VITE_FEATURE_NOTES_ENABLED
ARG VITE_FEATURE_SUBMIT_TABBED
ENV VITE_FEATURE_SUBMIT_TABBED=$VITE_FEATURE_SUBMIT_TABBED
ARG VITE_FEATURE_PATTERN_MASTERY_V2
ENV VITE_FEATURE_PATTERN_MASTERY_V2=$VITE_FEATURE_PATTERN_MASTERY_V2
ARG VITE_FEATURE_SOLUTION_DEPTH_V2
ENV VITE_FEATURE_SOLUTION_DEPTH_V2=$VITE_FEATURE_SOLUTION_DEPTH_V2
ARG VITE_FEATURE_COMMUNICATION_V2
ENV VITE_FEATURE_COMMUNICATION_V2=$VITE_FEATURE_COMMUNICATION_V2
ARG VITE_FEATURE_OPTIMIZATION_V2
ENV VITE_FEATURE_OPTIMIZATION_V2=$VITE_FEATURE_OPTIMIZATION_V2
ARG VITE_FEATURE_PRESSURE_PERFORMANCE_V2
ENV VITE_FEATURE_PRESSURE_PERFORMANCE_V2=$VITE_FEATURE_PRESSURE_PERFORMANCE_V2
ARG VITE_FEATURE_RETENTION_V2
ENV VITE_FEATURE_RETENTION_V2=$VITE_FEATURE_RETENTION_V2
ARG VITE_FEATURE_TEACHING_CONTRIBUTIONS_V2
ENV VITE_FEATURE_TEACHING_CONTRIBUTIONS_V2=$VITE_FEATURE_TEACHING_CONTRIBUTIONS_V2
ARG VITE_FEATURE_DESIGN_APTITUDE
ENV VITE_FEATURE_DESIGN_APTITUDE=$VITE_FEATURE_DESIGN_APTITUDE
ARG VITE_FEATURE_BEHAVIORAL_PERFORMANCE
ENV VITE_FEATURE_BEHAVIORAL_PERFORMANCE=$VITE_FEATURE_BEHAVIORAL_PERFORMANCE
ARG VITE_FEATURE_VERIFICATION_METACOGNITION
ENV VITE_FEATURE_VERIFICATION_METACOGNITION=$VITE_FEATURE_VERIFICATION_METACOGNITION
ARG VITE_FEATURE_MCP_ENABLED
ENV VITE_FEATURE_MCP_ENABLED=$VITE_FEATURE_MCP_ENABLED
ARG VITE_FEATURE_CANONICAL_ANSWERS=false
ENV VITE_FEATURE_CANONICAL_ANSWERS=$VITE_FEATURE_CANONICAL_ANSWERS
ARG VITE_FEATURE_CANONICAL_ALTERNATIVES=false
ENV VITE_FEATURE_CANONICAL_ALTERNATIVES=$VITE_FEATURE_CANONICAL_ALTERNATIVES
ARG VITE_FEATURE_CURRICULUM=false
ENV VITE_FEATURE_CURRICULUM=$VITE_FEATURE_CURRICULUM
ARG VITE_MCP_URL
ENV VITE_MCP_URL=$VITE_MCP_URL

RUN npm run build

FROM node:20-alpine
WORKDIR /app
RUN npm install -g serve
COPY --from=builder /app/dist ./dist
EXPOSE 3000
CMD ["serve", "-s", "dist", "-l", "3000"]