# ── Server ────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────
# Development (SQLite):
DATABASE_URL="file:./prisma/dev.db"
# Production (PostgreSQL — replace with Railway's URL):
# DATABASE_URL="postgresql://user:pass@host:5432/dbname"

# ── Auth ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-very-long-random-secret-here
JWT_EXPIRES_IN=7d

# ── Admin ─────────────────────────────────────────────
ADMIN_PASSWORD=your-admin-password-here

# ── CORS ──────────────────────────────────────────────
# Development:
CLIENT_URL=http://localhost:5173
# Production (your Railway frontend URL):
# CLIENT_URL=https://your-app.up.railway.app

# ── AI (Phase 2) ──────────────────────────────────────
AI_ENABLED=false
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini
# Daily per-user AI call cap. Default 500. Lower if cost is a concern;
# raise (e.g. 1000) if power users routinely run into it.
# AI_DAILY_LIMIT=500

# Per-call hard ceiling on max_tokens. Existing legitimate callers ask for up
# to 8000 (batch problem generation). A misconfigured caller asking for 100k
# would silently inflate cost; the clamp inside aiComplete/aiStream enforces
# this regardless of caller intent. Default 8000.
# AI_MAX_TOKENS_HARD_CAP=8000

# Per-HTTP-call timeout for the OpenAI SDK (milliseconds). Default is the
# SDK's 600s, which holds a Node worker for 10 minutes on a stuck request —
# at any modest concurrency one OAI degradation freezes the server. 30s
# covers all known completion latencies (verdict P95 ~12s) with headroom.
# AI_REQUEST_TIMEOUT_MS=30000

# ── Feature flags ─────────────────────────────────────
# Team Teaching Sessions — peer-to-peer knowledge sharing.
# When `true`: /teaching routes mount, the 60s cron polls for session
# transitions, and the in-app room + AI artifacts go live for users.
# Mirror with VITE_FEATURE_TEACHING_SESSIONS in the client .env.
# FEATURE_TEACHING_SESSIONS=true

# Personal Notes + SM-2 Flashcards.
# When `true`: /notes + /flashcards routes mount and the sidebar entry
# appears in the client. Mirror with VITE_FEATURE_NOTES_ENABLED in the
# client .env AND declare ARG/ENV in client/Dockerfile (Railway runtime
# env does not auto-flow into vite build).
# FEATURE_NOTES_ENABLED=true

# Canonical Answers (Review Page rebuild).
# When true: canonical pattern/insight/complexity fields are served from Problem,
# AI lazy-fills on first review, admin-editable via SUPER_ADMIN PATCH.
# Mirror with VITE_FEATURE_CANONICAL_ANSWERS in client .env AND Dockerfile ARG/ENV.
# FEATURE_CANONICAL_ANSWERS=true

# Canonical Alternatives — multi-approach grading (layers on FEATURE_CANONICAL_ANSWERS).
# When true: AI generates 0-3 valid alternative approaches per problem.
# Grader matches user's recall to the closest approach (primary or alt) instead
# of always primary. Reveal panel shows alternatives expander.
# Mirror with VITE_FEATURE_CANONICAL_ALTERNATIVES in client .env AND Dockerfile ARG/ENV.
# FEATURE_CANONICAL_ALTERNATIVES=true
