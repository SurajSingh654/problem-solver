// ============================================================================
// ProbSolver v3.0 — Multi-Tenant Schema
// ============================================================================
//
// DESIGN DECISIONS:
//
// 1. IDs: Using @default(cuid()) — CUID is time-sortable (B-tree friendly),
//    collision-resistant, URL-safe, and shorter than UUID. Better index
//    locality than UUIDv4 since sequential inserts stay near each other
//    on disk pages. Prisma's default and battle-tested at scale.
//
// 2. Multi-tenancy: Shared database, shared schema, teamId foreign key
//    on every tenant-scoped table. Every query filters by teamId.
//    This is the simplest pattern that scales to thousands of teams
//    without operational complexity of schema-per-tenant.
//
// 3. Soft deletes: Using deletedAt timestamp (null = active) on Team
//    and User. Allows recovery, audit trails, and prevents orphaned
//    references. Partial indexes exclude soft-deleted rows from queries.
//
// 4. JSON columns: Used for semi-structured data that varies by context
//    (categoryData, aiProblemConfig, phases, workspace, debrief, scores).
//    These are never used in WHERE clauses — they're read/write blobs.
//    Structured data that we filter/sort on always gets its own column.
//
// 5. Vector columns: Handled via raw SQL in migrations since Prisma
//    doesn't natively support pgvector types. We use Unsupported("vector(1536)")
//    as a placeholder and create actual columns + HNSW indexes in migrations.
//    The db pull output shows these as Unsupported("vector") — both refer to
//    the same pgvector column. The (1536) dimension is enforced at the DB level.
//
// 6. Indexes: Every teamId FK has a composite index with the most common
//    co-filtered column (usually createdAt or userId). This ensures
//    the two most frequent query patterns — "all items in this team"
//    and "all items by this user in this team" — are index-only scans.
//    Vector HNSW indexes are created via raw SQL and registered here
//    with explicit map names so Prisma tracks them without drift.
//
// 7. Cascade rules: Deleting a Team cascades to all team-scoped data.
//    Deleting a User nullifies their authored content where possible
//    (problems stay, attributed to "[deleted user]") and cascades
//    personal data (solutions, sessions, messages).
//
// 8. SM-2 Spaced Repetition: sm2EasinessFactor, sm2Interval, sm2Repetitions
//    are proper columns on Solution (not JSON) so they can be read server-side
//    without deserialization. All SM-2 state is computed server-side only —
//    the client sends only a confidence rating (1-5). Added in migration
//    20260701000000_add_sm2_fields.
//
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector", schema: "public")]
}

// ============================================================================
// ENUMS
// ============================================================================

/// Platform-level role — only SUPER_ADMIN has platform-wide powers
enum GlobalRole {
  SUPER_ADMIN
  USER
}

/// Role within a specific team
enum TeamRole {
  TEAM_ADMIN
  MEMBER
}

/// Team lifecycle status — creation requires SUPER_ADMIN approval
enum TeamStatus {
  PENDING
  ACTIVE
  REJECTED
}

/// Team invitation status
enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

/// How the problem was created
enum ProblemSource {
  MANUAL
  AI_GENERATED
}

/// The 7 interview categories — covers every round type in modern SWE hiring
/// LOW_LEVEL_DESIGN added in migration 20260801000000_add_lld_category
enum ProblemCategory {
  CODING
  SYSTEM_DESIGN
  LOW_LEVEL_DESIGN
  BEHAVIORAL
  CS_FUNDAMENTALS
  HR
  SQL
}

/// Standard difficulty levels
enum Difficulty {
  EASY
  MEDIUM
  HARD
}

/// Mock interview session status
enum InterviewStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

/// Interview message role
enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

/// User activity classification — computed on login/action
enum ActivityStatus {
  ACTIVE
  INACTIVE
  DORMANT
}

/// Competition lifecycle (FUTURE)
enum CompetitionStatus {
  DRAFT
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

/// Feedback report type — what kind of report is this
enum FeedbackType {
  BUG
  SUGGESTION
  QUESTION
}

/// Feedback lifecycle status — admin tracks resolution
enum FeedbackStatus {
  OPEN
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  WONT_FIX
}

/// Bug severity — helps admin prioritize triage
enum FeedbackSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

/// Skill assessment session lifecycle
enum SkillAssessmentStatus {
  IN_PROGRESS
  PASSED
  FAILED
  ABANDONED
}

/// Dreyfus & Dreyfus (1980) skill acquisition model — 5 levels
/// Each level has a specific behavioural definition, not an arbitrary tier.
/// NOVICE:     0-25  — recognizes concept but cannot apply independently
/// DEVELOPING: 26-50 — can apply with prompting, needs frequent review
/// PROFICIENT: 51-75 — applies reliably in standard contexts
/// EXPERT:     76-90 — applies flexibly in novel contexts
/// MASTERY:    91-100 — explains, teaches, and adapts under pressure
enum SkillProficiencyLevel {
  NOVICE
  DEVELOPING
  PROFICIENT
  EXPERT
  MASTERY
}

/// Design Studio session type — HLD or LLD
enum DesignType {
  SYSTEM_DESIGN
  LOW_LEVEL_DESIGN
}

/// Design Studio session lifecycle
enum DesignSessionStatus {
  IN_PROGRESS
  VALIDATING
  COMPLETED
  ABANDONED
}

/// Design Studio session modality.
/// SELF_PACED is the default — user works at their own speed with on-demand AI coaching.
/// INTERVIEW pairs the session with a real-time AI-interviewer InterviewSession via
/// `interviewSessions` and adds time pressure. The interviewer can read the live
/// workspace (phases, annotations, dataFlow) via the `getDesignWorkspace` tool.
enum DesignSessionMode {
  SELF_PACED
  INTERVIEW
}

// ============================================================================
// USER
// ============================================================================

/// The user model — every person on the platform
///
/// Key design: globalRole controls platform-level access.
/// currentTeamId + teamRole control team-level access.
/// When currentTeamId is null AND the user has a personal team,
/// they're in "individual mode."
model User {
  id        String  @id @default(cuid())
  email     String  @unique
  password  String
  name      String
  avatarUrl String?

  // ── Platform role ──────────────────────────────────
  globalRole GlobalRole @default(USER)

  // ── Current team context ───────────────────────────
  // Which team the user is currently operating in.
  // Null means they haven't joined a team / are in individual mode.
  // This is denormalized for fast JWT embedding and query filtering.
  currentTeamId String?
  currentTeam   Team?     @relation("CurrentTeamMembers", fields: [currentTeamId], references: [id], onDelete: SetNull)
  teamRole      TeamRole?

  // ── Personal space ─────────────────────────────────
  // Every individual-mode user gets a hidden "personal team."
  // This ID links to that team for uniform query patterns.
  personalTeamId String? @unique
  personalTeam   Team?   @relation("PersonalTeam", fields: [personalTeamId], references: [id], onDelete: SetNull)

  // ── Onboarding ─────────────────────────────────────
  onboardingComplete Boolean @default(false)

  // ── Email verification ─────────────────────────────
  isVerified         Boolean   @default(false)
  verificationCode   String?
  verificationExpiry DateTime?

  // ── Password reset ─────────────────────────────────
  resetCode          String?
  resetExpiry        DateTime?
  mustChangePassword Boolean   @default(false)

  // ── Email change ───────────────────────────────────
  pendingEmail      String?
  emailChangeCode   String?
  emailChangeExpiry DateTime?

  // ── Interview prep profile ─────────────────────────
  targetCompany     String?
  interviewDate     DateTime?
  preferredLanguage String?

  // ── Activity tracking ──────────────────────────────
  streak         Int            @default(0)
  lastSolvedAt   DateTime?
  lastActiveAt   DateTime?
  activityStatus ActivityStatus @default(ACTIVE)

  // ── AI problem preferences (individual mode) ───────
  // JSON: { categories: [...], difficulty: "MEDIUM", dailyCount: 2,
  //         targetCompanyStyle: "google", patterns: [...] }
  aiProblemConfig Json?

  feedbackReports FeedbackReport[]

  designSessions DesignSession[]

  // ── Soft delete ────────────────────────────────────
  deletedAt DateTime?

  // ── Timestamps ─────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ──────────────────────────────────────
  createdTeams        Team[]             @relation("TeamCreator")
  teamInvitesSent     TeamInvitation[]   @relation("InviteSender")
  problems            Problem[]          @relation("ProblemAuthor")
  solutions           Solution[]
  clarityRatingsGiven ClarityRating[]    @relation("RatingAuthor")
  simSessions         SimSession[]
  quizAttempts        QuizAttempt[]
  interviewSessions   InterviewSession[]
  memberships         TeamMembership[]

  skillProfiles    SkillProfile[]
  skillAssessments SkillAssessment[]

  verdictLogs VerdictLog[]
  usageEvents UsageTracking[]

  // Personal notes + spaced-repetition flashcards. Both are user-scoped
  // (no teamId) — they survive team switches.
  notes      Note[]
  flashcards Flashcard[]

  // Teaching sessions — host + attend + rate + flag back-relations.
  hostedTeachingSessions TeachingSession[]  @relation("TeachingHost")
  teachingAttendances    TeachingAttendee[] @relation("TeachingAttendee")
  teachingRatingsGiven   TeachingRating[]   @relation("TeachingRater")
  teachingFlagsRaised    TeachingFlag[]     @relation("TeachingFlagger")

  authoredDesignReferences DesignReference[] @relation("DesignReferenceAuthor")

  // ── Indexes ────────────────────────────────────────
  // Composite index for "all users in this team" — the most common query
  @@index([currentTeamId, activityStatus])
  // For leaderboard queries: team members sorted by streak/activity
  @@index([currentTeamId, streak])
  // For SUPER_ADMIN: find users by activity status platform-wide
  @@index([activityStatus, lastActiveAt])
  // Partial index for soft delete — only query non-deleted users
  @@index([deletedAt])
  // Fast email lookup compound with deletedAt ensures we only find active accounts
  @@index([email, deletedAt])
  @@map("users")
}

// ============================================================================
// TEAM
// ============================================================================

/// A team is the primary multi-tenant boundary.
///
/// Every piece of content (problems, solutions, sessions) belongs to a team.
/// Individual users get a "personal team" with isPersonal=true that behaves
/// identically in the database but is presented as "My Practice" in the UI.
model Team {
  id          String  @id @default(cuid())
  name        String
  description String?
  avatarUrl   String?

  // ── Lifecycle ──────────────────────────────────────
  status          TeamStatus @default(PENDING)
  rejectionReason String?
  approvedAt      DateTime?

  // ── Join code — generated on approval ──────────────
  // 8-char alphanumeric, unique, regeneratable by team admin
  joinCode String? @unique

  // ── Creator ────────────────────────────────────────
  createdById String
  createdBy   User   @relation("TeamCreator", fields: [createdById], references: [id], onDelete: Cascade)

  // ── Team config ────────────────────────────────────
  maxMembers Int @default(20)

  // ── Personal team flag ─────────────────────────────
  // True for auto-created individual spaces.
  // Personal teams don't appear in search, can't be joined,
  // and don't require approval.
  isPersonal Boolean @default(false)

  // ── AI problem generation config ───────────────────
  // JSON: { enabled: true, categories: [...], difficultyDistribution: {...},
  //         frequency: "daily", autoPublish: false, targetCompanyStyle: "google" }
  aiProblemsEnabled Boolean @default(true)
  aiProblemConfig   Json?

  feedbackReports FeedbackReport[]

  designSessions DesignSession[]

  // ── Soft delete ────────────────────────────────────
  deletedAt DateTime?

  // ── Timestamps ─────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ──────────────────────────────────────
  currentMembers    User[]             @relation("CurrentTeamMembers")
  personalOwner     User?              @relation("PersonalTeam")
  invitations       TeamInvitation[]
  problems          Problem[]
  solutions         Solution[]
  clarityRatings    ClarityRating[]
  simSessions       SimSession[]
  quizAttempts      QuizAttempt[]
  interviewSessions InterviewSession[]
  memberships       TeamMembership[]
  verdictLogs       VerdictLog[]
  usageEvents       UsageTracking[]
  teachingSessions  TeachingSession[]

  // ── Indexes ────────────────────────────────────────
  // For SUPER_ADMIN: list teams by status (pending approvals)
  @@index([status, createdAt])
  // For filtering out personal teams in team search/listings
  @@index([isPersonal, status])
  // Soft delete filtering
  @@index([deletedAt])
  @@map("teams")
}

// ============================================================================
// TEAM INVITATION
// ============================================================================

/// Invitations to join a team — sent by TEAM_ADMIN via email
model TeamInvitation {
  id String @id @default(cuid())

  // ── Team ───────────────────────────────────────────
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // ── Invitee ────────────────────────────────────────
  email String

  // ── Inviter ────────────────────────────────────────
  invitedById String
  invitedBy   User   @relation("InviteSender", fields: [invitedById], references: [id], onDelete: Cascade)

  // ── Status ─────────────────────────────────────────
  status InvitationStatus @default(PENDING)

  // ── Invite link token ──────────────────────────────
  token String @unique @default(cuid())

  // ── Expiry ─────────────────────────────────────────
  expiresAt DateTime

  // ── Timestamps ─────────────────────────────────────
  createdAt DateTime @default(now())

  // ── Indexes ────────────────────────────────────────
  // Find pending invitations for a given email (registration flow)
  @@index([email, status])
  // Find all invitations for a team (admin view)
  @@index([teamId, status])
  @@map("team_invitations")
}

// ============================================================================
// TEAM MEMBERSHIP
// ============================================================================

/// Explicit record of every user-team relationship.
///
/// DESIGN DECISIONS:
///
/// 1. Separates membership (permanent) from context (temporary).
///    User.currentTeamId = "what I am looking at right now."
///    TeamMembership = "what teams I belong to and with what role."
///
/// 2. User.teamRole is a denormalized cache of the role in the
///    current team for fast JWT embedding and query filtering.
///    TeamMembership.role is the authoritative source of truth.
///    They must be kept in sync whenever currentTeamId changes.
///
/// 3. isActive flag allows soft-leaving a team without losing history.
///    A user can be re-added to a team they previously left without
///    losing their solutions, quiz history, or interview sessions.
///
/// 4. Personal teams ARE included here (isPersonal = true on Team).
///    This gives a uniform "all my teams" query without special-casing
///    the personal space.
model TeamMembership {
  id String @id @default(cuid())

  // ── User ───────────────────────────────────────────
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Team ───────────────────────────────────────────
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // ── Role in this specific team ─────────────────────
  // This is the authoritative role. User.teamRole is a
  // denormalized cache that must match this when the user
  // is currently viewing this team.
  role TeamRole @default(MEMBER)

  // ── Membership status ──────────────────────────────
  // false = user has left the team (soft leave)
  // Content created while active is preserved.
  isActive Boolean   @default(true)
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  // ── Constraints ────────────────────────────────────
  @@unique([userId, teamId])
  // ── Indexes ────────────────────────────────────────
  // "All active teams this user belongs to" — for sidebar switcher
  @@index([userId, isActive])
  // "All active members of this team" — for team management
  @@index([teamId, isActive])
  @@map("team_memberships")
}

// ============================================================================
// PROBLEM
// ============================================================================

/// An interview problem — always belongs to a team.
///
/// For team mode: created by TEAM_ADMIN manually or AI-generated.
/// For individual mode: AI-generated into the user's personal team.
/// Embeddings enable vector similarity search scoped to the team.
model Problem {
  id    String @id @default(cuid())
  title String

  // ── Content ────────────────────────────────────────
  description  String?
  difficulty   Difficulty      @default(MEDIUM)
  category     ProblemCategory @default(CODING)
  categoryData Json?

  // ── Context & metadata ─────────────────────────────
  tags             String[] @default([])
  realWorldContext String?
  useCases         String?
  adminNotes       String?

  // ── Source tracking ────────────────────────────────
  source ProblemSource @default(MANUAL)

  // ── Team ownership (required) ──────────────────────
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // ── Author ─────────────────────────────────────────
  createdById String
  createdBy   User   @relation("ProblemAuthor", fields: [createdById], references: [id], onDelete: Cascade)

  // ── Publishing (for AI-generated review workflow) ──
  isPublished Boolean @default(true)

  // ── Pinning & visibility ───────────────────────────
  isPinned Boolean @default(false)
  isHidden Boolean @default(false)

  // ── Assessment pool flag ───────────────────────────────
  // Problems with isAssessmentOnly=true are exclusively for
  // skill assessments. They are never shown in the practice pool.
  // This is the transfer condition that makes skill claims defensible:
  // a user who passes an assessment demonstrated skill on problems
  // they had never seen during practice.
  isAssessmentOnly Boolean @default(false)

  // ── Content version ───────────────────────────────────
  // Bumped by updateProblem whenever the problem STATEMENT changes
  // (title, description, categoryData, tags, adminNotes, realWorldContext,
  // useCases, difficulty, category). NOT bumped by admin-only flags
  // (isPinned, isHidden, isPublished) — those don't affect what the
  // candidate saw. Solutions capture the version they were submitted
  // against, so the client can flag "this problem has been updated
  // since you solved it."
  version Int @default(1)

  assessmentResponses AssessmentResponse[]

  designSessions   DesignSession[]
  designReferences DesignReference[]

  // ── Vector embedding ───────────────────────────────
  // Column + HNSW index created via raw SQL migration:
  //   ALTER TABLE problems ADD COLUMN embedding vector(1536);
  //   CREATE INDEX idx_problems_embedding_hnsw ON problems
  //     USING hnsw (embedding vector_cosine_ops) WITH (m = 16, ef_construction = 64);
  // Registered below with explicit map name to prevent migration drift.
  embedding Unsupported("vector(1536)")?

  // ── Timestamps ─────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ──────────────────────────────────────
  followUpQuestions FollowUpQuestion[]
  solutions         Solution[]
  simSessions       SimSession[]
  interviewSessions InterviewSession[]

  // ── Indexes ────────────────────────────────────────
  // THE critical multi-tenant index: "all problems in this team"
  @@index([teamId, category, difficulty])
  // For problem listings: team + published + not hidden
  @@index([teamId, isPublished, isHidden])
  // For pinned problems (shown at top)
  @@index([teamId, isPinned])
  // Full-text search candidate (title)
  @@index([teamId, title])
  // For AI-generated review queue: unpublished in a team
  @@index([teamId, source, isPublished])
  // HNSW vector index — registered to prevent drift detection
  @@index([embedding], map: "idx_problems_embedding_hnsw")
  // Assessment pool queries
  @@index([isAssessmentOnly, category])
  @@map("problems")
}

// ============================================================================
// FOLLOW-UP QUESTION
// ============================================================================

/// Progressive follow-up questions attached to a problem.
/// No teamId needed — follows the problem's team scope.
model FollowUpQuestion {
  id String @id @default(cuid())

  // ── Parent problem ─────────────────────────────────
  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  // ── Content ────────────────────────────────────────
  question   String
  difficulty Difficulty @default(MEDIUM)
  hint       String?
  order      Int        @default(0)

  // ── Timestamps ─────────────────────────────────────
  createdAt DateTime @default(now())

  // ── Relations ──────────────────────────────────────
  answers SolutionFollowUpAnswer[]

  // ── Indexes ────────────────────────────────────────
  @@index([problemId, order])
  @@map("follow_up_questions")
}

// ============================================================================
// SOLUTION FOLLOW-UP ANSWER
// ============================================================================

/// A member's answer to a follow-up question as part of their solution.
///
/// DESIGN DECISIONS:
///
/// 1. Separate model (not JSON in Solution) — enables per-answer AI scoring,
///    team analytics on which follow-ups are hardest, and future features
///    like "show me teammates' answers to follow-up 2."
///
/// 2. aiScore is nullable — set after AI review, not at submission time.
///    This allows submission without waiting for AI analysis.
///
/// 3. No teamId — follows Solution's team scope through the FK chain:
///    SolutionFollowUpAnswer → Solution → teamId
///    This avoids denormalization while keeping queries simple.
model SolutionFollowUpAnswer {
  id String @id @default(cuid())

  // ── Solution reference ─────────────────────────────
  solutionId String
  solution   Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)

  // ── Question reference ─────────────────────────────
  followUpQuestionId String
  followUpQuestion   FollowUpQuestion @relation(fields: [followUpQuestionId], references: [id], onDelete: Cascade)

  // ── Answer content ─────────────────────────────────
  answerText String

  // ── AI evaluation ──────────────────────────────────
  // Set after reviewSolution is called — null until then
  aiScore    Int? // 1-10
  aiFeedback String? // One sentence feedback on this specific answer

  // ── Timestamps ─────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Constraints ────────────────────────────────────
  // One answer per follow-up per solution
  @@unique([solutionId, followUpQuestionId])
  // ── Indexes ────────────────────────────────────────
  @@index([solutionId])
  // "All answers to this follow-up question" — for team analytics
  @@index([followUpQuestionId])
  @@map("solution_follow_up_answers")
}

// ============================================================================
// SOLUTION
// ============================================================================

/// A user's solution to a problem — scoped to a team.
///
/// Contains multi-step approach (brute → optimized), code,
/// complexity analysis, explanations, and AI feedback.
/// Embeddings enable RAG: "find similar solutions in this team."
model Solution {
  id String @id @default(cuid())

  // ── Problem reference ──────────────────────────────
  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  // Frozen at submission time so the client can detect "problem has been
  // updated since you solved it." Null on legacy rows (pre-versioning).
  problemVersion Int?

  // ── Author ─────────────────────────────────────────
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Team scope ─────────────────────────────────────
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // ── Solution content ───────────────────────────────
  approach          String?
  code              String?
  language          String?
  bruteForce        String?
  optimizedApproach String?
  timeComplexity    String?
  spaceComplexity   String?

  // ── Deep understanding fields ──────────────────────
  keyInsight          String?
  feynmanExplanation  String?
  realWorldConnection String?

  // ── Self-assessment ────────────────────────────────
  confidence Int @default(3)

  // ── Pattern recognition ────────────────────────────
  // Multi-select: a solution can apply multiple patterns (e.g. Hashing
  // + Sliding Window). Empty array = no pattern claimed. First element
  // is treated as "primary" where a single-value read is required.
  patterns                  String[] @default([])
  patternIdentificationTime Int?

  // ── AI feedback (stored after review) ──────────────
  aiFeedback Json?

  // SHA-256 hash of the review input fields (problemVersion + content +
  // patterns + follow-up answers + categorySpecificData). When reviewSolution
  // runs, if the current hash matches this, return the latest aiFeedback as
  // a cache hit (no OpenAI call). Bypassed by `force: true` in the request.
  // Null on legacy rows — first re-analysis populates.
  aiFeedbackInputHash String?

  // ── Spaced repetition — SM-2 Algorithm ─────────────
  // Based on Wozniak (1990) SuperMemo SM-2 algorithm.
  //
  // sm2EasinessFactor: how fast intervals grow (min 1.3, default 2.5)
  //   Increases on high quality recall, decreases on low quality.
  //   Higher EF = item spaces out faster over successive reviews.
  //
  // sm2Interval: days until next review
  //   Rep 1 → 1 day, Rep 2 → 6 days, Rep n → prev * EF
  //   Reset to 1 on quality < 3 (forgot it).
  //
  // sm2Repetitions: consecutive successful reviews (quality >= 3)
  //   Reset to 0 on quality < 3. Drives interval progression.
  //
  // reviewDates: JSON array of past review timestamps (audit trail)
  // nextReviewDate: indexed DateTime for queue queries
  // reviewCount: total reviews including resets (not same as sm2Repetitions)
  // lastReviewedAt: set server-side on each review save
  //
  // IMPORTANT: All SM-2 state is computed server-side only.
  // Client sends only confidence (1-5). Server maps to quality (0-5)
  // and runs calculateSM2() from server/src/utils/sm2.js.
  reviewDates       Json?
  nextReviewDate    DateTime?
  reviewCount       Int       @default(0)
  lastReviewedAt    DateTime?
  sm2EasinessFactor Float     @default(2.5)
  sm2Interval       Int       @default(1)
  sm2Repetitions    Int       @default(0)
  // Cumulative count of failed recalls (quality < 3). Distinct from
  // sm2Repetitions (which resets on each failure). Items with
  // lapseCount >= 8 are flagged as "leeches" — they keep tripping the
  // user up and warrant extra attention. Convention from Anki.
  lapseCount        Int       @default(0)

  // ── Category-specific submission data ──────────────
  // Stores structured fields that vary by problem category.
  // For SYSTEM_DESIGN: { functionalRequirements, nonFunctionalRequirements,
  //   capacityEstimation, apiDesign, schemaDesign, architectureNotes,
  //   tradeoffReasoning, databaseChoice, databaseJustification }
  // For LOW_LEVEL_DESIGN: { entities, classHierarchy, designPatterns,
  //   solidAnalysis, extensibilityAnalysis }
  // Null for CODING, SQL, BEHAVIORAL, HR, CS_FUNDAMENTALS —
  // those categories use the existing text fields adequately.
  categorySpecificData Json?

  // ── Vector embedding ───────────────────────────────
  // Column + HNSW index created via raw SQL migration:
  //   ALTER TABLE solutions ADD COLUMN embedding vector(1536);
  //   CREATE INDEX idx_solutions_embedding_hnsw ON solutions
  //     USING hnsw (embedding vector_cosine_ops) WITH (m = 16, ef_construction = 64);
  // Registered below with explicit map name to prevent migration drift.
  embedding Unsupported("vector(1536)")?

  // ── Timestamps ─────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ──────────────────────────────────────
  clarityRatings  ClarityRating[]
  followUpAnswers SolutionFollowUpAnswer[]
  reviewAttempts  ReviewAttempt[]
  attempts        SolutionAttempt[]

  // ── Constraints ────────────────────────────────────
  // One solution per user per problem per team
  @@unique([userId, problemId, teamId])
  // ── Indexes ────────────────────────────────────────
  // THE critical query: "all solutions for this problem in this team"
  @@index([teamId, problemId])
  // "All solutions by this user in this team" (profile page)
  @@index([teamId, userId])
  // Spaced repetition queue: "my due reviews in this team"
  // This is the primary index for getReviewQueue — nextReviewDate lte now
  @@index([teamId, userId, nextReviewDate])
  // General timeline queries
  @@index([teamId, userId, createdAt])
  // Leaderboard: sorted by most recent per user per team (DESC)
  @@index([teamId, userId, createdAt(sort: Desc)], map: "idx_solutions_leaderboard")
  // HNSW vector index — registered to prevent drift detection
  @@index([embedding], map: "idx_solutions_embedding_hnsw")
  @@map("solutions")
}

// ============================================================================
// SOLUTION ATTEMPT
// ============================================================================

/// Per-submission/per-edit snapshot of a Solution's content. The Solution
/// row always holds the latest state; SolutionAttempt rows are an immutable
/// history of everything that ever got written to it. Lets the user see how
/// their solution evolved, diff between attempts, and track confidence
/// trajectory over time.
///
/// Distinct from ReviewAttempt (which captures SM-2 review recall text).
/// A ReviewAttempt is "I tried to remember what I wrote"; a SolutionAttempt
/// is "here is what I actually wrote this time."
enum AttemptTrigger {
  SUBMIT // initial Solution.create via submitSolution
  EDIT // Solution.update via updateSolution
  DESIGN_BRIDGE // DesignSession → Solution upsert
}

model SolutionAttempt {
  id String @id @default(cuid())

  solutionId String
  solution   Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)

  // 1-indexed, monotonic per solution. Unique constraint below ensures
  // we can't accidentally duplicate an attempt number.
  attemptNumber Int

  // How this attempt came into being. Lets the history UI show which
  // edits were user-initiated vs bridged from a design session etc.
  trigger AttemptTrigger

  // Frozen content snapshot (mirrors Solution writable columns so we can
  // reconstruct exactly what was saved at this attempt).
  approach             String?
  code                 String?
  language             String?
  bruteForce           String?
  optimizedApproach    String?
  timeComplexity       String?
  spaceComplexity      String?
  keyInsight           String?
  feynmanExplanation   String?
  realWorldConnection  String?
  confidence           Int
  patterns             String[] @default([])
  categorySpecificData Json?

  // Problem version this attempt was written against. Lets a later reader
  // see "you solved against v2; problem is now v5".
  problemVersion Int?

  // Frozen AI review JSON at attempt time, if one ran. The Solution's
  // `aiFeedback` field is the growing live store; this snapshot captures
  // the review entry that was most relevant to THIS attempt, so attempt
  // diffs can also show AI score deltas.
  aiFeedbackSnapshot Json?

  createdAt DateTime @default(now())

  @@unique([solutionId, attemptNumber])
  @@index([solutionId, createdAt(sort: Desc)])
  @@map("solution_attempts")
}

// ============================================================================
// REVIEW ATTEMPT
// ============================================================================

/// One row per SM-2 review event. Captures what the user recalled BEFORE
/// revealing their stored solution — i.e. the retrieval-practice attempt
/// text. Enables over-time analysis of recall quality, gives the AI
/// hint-generator the user's actual attempt to react to, and provides a
/// real audit trail (superseding the `Solution.reviewDates` JSON, which
/// stores only timestamps).
///
/// Research basis: Karpicke & Roediger (2008), "The critical importance
/// of retrieval for learning." Retrieval attempts are the single most
/// empirically-validated learning technique; storing them unlocks
/// feedback loops the timestamp-only log cannot support.
model ReviewAttempt {
  id String @id @default(cuid())

  // ── Parent solution ────────────────────────────────
  solutionId String
  solution   Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)

  // ── Recall attempt ─────────────────────────────────
  // Null when the user skipped typing a recall (timer expired or they
  // just clicked Reveal). Still a review event, just no attempt text.
  recallText String?

  // ── Outcome ────────────────────────────────────────
  confidence Int // 1-5, user-reported
  quality    Int // 0-5, SM-2 quality derived from confidence
  recalled   Boolean // quality >= 3

  // ── Timing ─────────────────────────────────────────
  createdAt DateTime @default(now())

  // Most-recent-first lookup for generateReviewHints + recall history UI
  @@index([solutionId, createdAt(sort: Desc)])
  @@map("review_attempts")
}

// ============================================================================
// VERDICT LOG
// ============================================================================

/// Audit record for every AI-generated readiness verdict.
///
/// Serves three purposes:
///   1. **5-minute cache** — hash of input evidence. If a matching log
///      exists within the window, we return its verdictJson instead of
///      re-calling the LLM (cost + latency control).
///   2. **Validation audit** — usedFallback=true marks verdicts where the
///      LLM violated one of the 7 hard rules and we returned a
///      deterministic template instead. Watching this rate tells us
///      whether the prompt is holding.
///   3. **Calibration ground truth** — interviewOutcome fields stay null
///      until the interview-pipeline-tracker feature lands; then back-fill
///      lets us plot "what we claimed" vs "what actually happened" and
///      re-tune thresholds against real outcomes. See plan section "L4".
model VerdictLog {
  id String @id @default(cuid())

  // ── Ownership (team-scoped) ────────────────────────
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // ── Cache key ──────────────────────────────────────
  // Stable hash of the structured evidence block. (userId, teamId,
  // inputHash) within 5 min → cache hit.
  inputHash String

  // ── Payload ────────────────────────────────────────
  inputPayload Json // exact evidence sent to the LLM
  verdictJson  Json // structured verdict (post-validation)
  usedFallback Boolean @default(false)

  // ── Calibration (future) ───────────────────────────
  interviewOutcome String? // 'passed' | 'failed'
  interviewCompany String?
  interviewDate    DateTime?

  createdAt DateTime @default(now())

  // Hot path: "latest verdict for this user/team" → dashboard badge
  @@index([userId, teamId, createdAt(sort: Desc)])
  // Cache lookup by input hash
  @@index([userId, teamId, inputHash])
  @@map("verdict_logs")
}

// ============================================================================
// CLARITY RATING
// ============================================================================

/// Peer rating of a solution's explanation quality (1-5 stars).
/// Feeds into the Communication dimension (D3) of the 6D report.
model ClarityRating {
  id String @id @default(cuid())

  // ── Solution being rated ───────────────────────────
  solutionId String
  solution   Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)

  // ── Rater ──────────────────────────────────────────
  raterId String
  rater   User   @relation("RatingAuthor", fields: [raterId], references: [id], onDelete: Cascade)

  // ── Team scope ─────────────────────────────────────
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // ── Rating ─────────────────────────────────────────
  rating Int // 1-5

  // ── Timestamps ─────────────────────────────────────
  createdAt DateTime @default(now())

  // ── Constraints ────────────────────────────────────
  // One rating per user per solution
  @@unique([raterId, solutionId])
  // ── Indexes ────────────────────────────────────────
  // Aggregate ratings for a solution
  @@index([solutionId])
  // Team-scoped rating queries
  @@index([teamId])
  @@map("clarity_ratings")
}

// ============================================================================
// SIM SESSION (Timer-based practice)
// ============================================================================

/// A timed problem-solving simulation session.
/// @deprecated — legacy "Timed Simulation" feature; no code path writes to
/// or reads from this table anymore. Replaced end-to-end by `InterviewSession`
/// (mock interviews). Model + relations are kept for now so historical rows
/// aren't silently dropped; remove the model + drop the table in a dedicated
/// migration when there's appetite for the data-loss decision.
model SimSession {
  id String @id @default(cuid())

  // ── User & team ────────────────────────────────────
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // ── Problem ────────────────────────────────────────
  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  // ── Session data ───────────────────────────────────
  score       Int?
  hintsUsed   Int       @default(0)
  completed   Boolean   @default(false)
  abandoned   Boolean   @default(false)
  timeSpent   Int?
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  // ── Timestamps ─────────────────────────────────────
  createdAt DateTime @default(now())

  // ── Indexes ────────────────────────────────────────
  @@index([teamId, userId, createdAt])
  @@index([teamId, completed])
  @@map("sim_sessions")
}

// ============================================================================
// QUIZ ATTEMPT
// ============================================================================

/// An AI-generated quiz attempt on any subject.
/// teamId is optional — quizzes work in both team and individual context.
model QuizAttempt {
  id String @id @default(cuid())

  // ── User ───────────────────────────────────────────
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Team scope (optional — works in both modes) ────
  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  // ── Quiz content ───────────────────────────────────
  subject    String
  difficulty Difficulty @default(MEDIUM)
  questions  Json
  answers    Json?
  score      Int?

  // ── AI analysis (post-quiz) ────────────────────────
  aiAnalysis Json?

  // ── Timing ─────────────────────────────────────────
  timeSpent   Int?
  completedAt DateTime?

  // ── Timestamps ─────────────────────────────────────
  createdAt DateTime @default(now())

  // ── Indexes ────────────────────────────────────────
  // "My quizzes" — personal regardless of team
  @@index([userId, createdAt])
  // Team-scoped quiz stats
  @@index([teamId, createdAt])
  @@map("quiz_attempts")
}

// ============================================================================
// INTERVIEW SESSION (AI Mock Interview)
// ============================================================================

/// A GPT-4o powered mock interview session.
///
/// Contains the full interview lifecycle: configuration, phases,
/// workspace artifacts, and the final debrief with scores.
model InterviewSession {
  id String @id @default(cuid())

  // ── User & team ────────────────────────────────────
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  // ── Problem (optional — can be AI-selected) ────────
  problemId String?
  problem   Problem? @relation(fields: [problemId], references: [id], onDelete: SetNull)

  // ── Paired Design Studio session (INTERVIEW mode only) ─
  // When set, this InterviewSession is the AI-interviewer half of a
  // Design Studio session running in INTERVIEW mode. The interviewer's
  // system prompt branches on this — DESIGN_INTERVIEW_STAGE_BEHAVIOR is
  // injected, the `getDesignWorkspace` tool becomes available, and the
  // hint ladder switches from CODING-shaped to design-shaped.
  // SetNull on delete — the InterviewSession's transcript outlives the
  // DS session for audit even if the DS row is removed.
  designSessionId String?
  designSession   DesignSession? @relation(fields: [designSessionId], references: [id], onDelete: SetNull)

  // ── Interview configuration ────────────────────────
  category       ProblemCategory @default(CODING)
  difficulty     Difficulty      @default(MEDIUM)
  interviewStyle String?

  // 1-5 self-rated readiness captured BEFORE the session begins. Used by
  // the debrief to compute a calibration gap ("you rated 4/5 prepared but
  // scored 2/5 on accuracy") — making self-awareness a measurable signal
  // rather than a vague feeling. Nullable because it's optional / skippable.
  preSessionConfidence Int?

  // ── Session state ──────────────────────────────────
  status    InterviewStatus @default(IN_PROGRESS)
  phases    Json?
  workspace Json?

  // ── Results ────────────────────────────────────────
  debrief Json?
  scores  Json?

  // ── Timing ─────────────────────────────────────────
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  // ── Timestamps ─────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ──────────────────────────────────────
  messages InterviewMessage[]

  // ── Indexes ────────────────────────────────────────
  @@index([userId, createdAt])
  @@index([teamId, createdAt])
  // Active sessions (for cleanup/monitoring)
  @@index([status, createdAt])
  // Lookup the paired interview for a Design Studio session
  @@index([designSessionId])
  @@map("interview_sessions")
}

// ============================================================================
// INTERVIEW MESSAGE
// ============================================================================

/// A single message in a mock interview conversation.
///
/// Stores the full conversation transcript including tool calls,
/// workspace snapshots at each turn, and phase tags.
model InterviewMessage {
  id String @id @default(cuid())

  // ── Session reference ──────────────────────────────
  sessionId String
  session   InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // ── Message content ────────────────────────────────
  role    MessageRole
  content String?

  // ── Tool calling ───────────────────────────────────
  toolCalls   Json?
  toolResults Json?

  // ── Context snapshots ──────────────────────────────
  workspaceSnapshot Json?
  phase             String?

  // ── Timestamps ─────────────────────────────────────
  createdAt DateTime @default(now())

  // ── Indexes ────────────────────────────────────────
  // Sequential message retrieval for a session
  @@index([sessionId, createdAt])
  @@map("interview_messages")
}

// ============================================================================
// DESIGN SESSION (Design Studio — Practice + Validate + Evaluate)
// ============================================================================
/// A self-paced design practice session in the Design Studio.
///
/// DESIGN DECISIONS:
///
/// 1. Separate from Solution model. A Solution is a one-shot submission to a
///    specific problem that gets AI-reviewed once. A DesignSession is an
///    iterative practice environment with per-phase AI coaching, scenario
///    testing, flow simulation, and comprehensive evaluation. The data shapes,
///    lifecycle, and interaction patterns are fundamentally different.
///
/// 2. Separate from InterviewSession. The Mock Interview is a real-time
///    conversational AI interaction over WebSocket with streaming. The Design
///    Studio is self-paced, phase-based, with on-demand AI coaching (not
///    streaming conversation). Different UX, different AI interaction model.
///
/// 3. Multiple sessions per problem allowed (no unique constraint on
///    userId+problemId). Users should practice the same design problem
///    multiple times and see improvement over attempts. This is deliberate
///    practice — repetition with feedback is how expertise develops.
///
/// 4. JSON columns for phase data. Each phase stores structured content
///    that varies by design type (HLD vs LLD) and phase. These are never
///    used in WHERE clauses — they're read/write blobs persisted per save.
///    Using JSON avoids 11+ nullable text columns that would be sparse.
///
/// 5. AI interactions stored in a JSON array on the session (not a separate
///    table). Rationale: interactions are always read/written with the session,
///    never queried independently, and keeping them inline avoids N+1 queries
///    when loading a session. Estimated max: ~50 interactions per session
///    (3-5 per phase × 11 phases) — well within JSON column performance.
///
/// 6. diagramData stores the Excalidraw elements JSON string. This can be
///    large (50-200KB for complex diagrams) but is always loaded with the
///    session and never queried. String type (not Json) because Excalidraw
///    outputs a serialized string that we pass through unchanged.
///
/// 7. Timer is soft (elapsed time tracked, no auto-advance). The session
///    stores totalTimeSpent (seconds) and per-phase time in phaseTimings JSON.
///    This enables analytics: "You spend 40% of time on requirements but
///    only 10% on trade-offs — that's inverted from what interviewers expect."
///
/// 8. Scoring uses the same 0-10 scale as Solution reviews for consistency
///    across the platform. The 10 evaluation dimensions are stored as a JSON
///    object in the evaluation field (not 10 separate Float columns) because
///    dimensions may evolve and we don't want a migration every time we
///    refine the scoring model.
///
/// 9. problemId is optional. Users can start a freeform design session
///    without selecting a specific problem (e.g., "I want to practice
///    designing a chat app" without it being tied to a team problem).
///    When present, enables comparison across users on the same problem.
///
/// 10. teamId is optional. Works in both team and individual (personal) mode.
///     When in team mode, enables team-wide analytics: "Which design problems
///     does the team struggle with most?"
model DesignSession {
  id String @id @default(cuid())

  // ── User ───────────────────────────────────────────
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Team scope (optional) ──────────────────────────
  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  // ── Problem reference (optional — freeform allowed) ─
  problemId String?
  problem   Problem? @relation(fields: [problemId], references: [id], onDelete: SetNull)

  // ── Session configuration ──────────────────────────
  designType DesignType
  difficulty Difficulty @default(MEDIUM)
  title      String // User-facing title: problem title or custom name

  // ── Modality ───────────────────────────────────────
  // SELF_PACED (default): work at your own speed with on-demand AI coaching.
  // INTERVIEW: paired with a real-time AI-interviewer InterviewSession (see
  // `interviewSessions`) — countdown timer, interviewer can read the live
  // workspace via the `getDesignWorkspace` tool. Set on creation by the
  // POST /design-studio/sessions/:id/interview endpoint.
  mode DesignSessionMode @default(SELF_PACED)

  // ── Session lifecycle ──────────────────────────────
  status DesignSessionStatus @default(IN_PROGRESS)

  // ── Current progress ───────────────────────────────
  // Which phase the user is currently on (0-indexed)
  // Used to restore position when resuming a session
  currentPhase Int @default(0)

  // ── DESIGN PHASE DATA ──────────────────────────────
  // JSON object with keys matching phase IDs.
  // For SYSTEM_DESIGN:
  //   { requirements, capacityEstimation, apiDesign, dataModel,
  //     architecture, deepDive, tradeoffs }
  // For LOW_LEVEL_DESIGN:
  //   { requirements, entities, classHierarchy, designPatterns,
  //     methodSignatures, solidAnalysis }
  // Each value is the user's text content for that phase.
  phases Json?

  // ── DIAGRAM DATA ───────────────────────────────────
  // Excalidraw elements JSON string — persisted across all phases.
  // Stored as String (not Json) because we pass it through unchanged.
  // Can be null if user hasn't drawn anything yet.
  diagramData String? @db.Text

  // ── COMPONENT ANNOTATIONS ──────────────────────────
  // JSON array of { componentName, purpose, technology, notes }
  // User annotates each component drawn on the canvas.
  // Separate from diagramData because AI reads this (not the diagram).
  componentAnnotations Json?

  // ── DATA FLOW DESCRIPTION ──────────────────────────
  // Text description of how data flows through the system.
  // AI uses this + componentAnnotations to understand the architecture
  // since it cannot see the visual diagram.
  dataFlowDescription String? @db.Text

  // ── VALIDATION PHASE DATA ──────────────────────────
  // scenarios: AI-generated scenarios tailored to this design
  //   Array of { id, scenario, userResponse, aiVerdict, status }
  //   status: 'pending' | 'answered' | 'evaluated'
  //   aiVerdict: 'PASS' | 'PARTIAL' | 'FAIL' + explanation
  scenarios Json?

  // flowSimulation: request path traces with latency annotations
  //   Array of { flowName, hops: [{ from, to, latency, payload, failureHandling }],
  //              totalLatency, bottleneck, spofWarnings }
  flowSimulation Json?

  // scaleAnalysis: user's analysis at 1x, 10x, 100x scale
  //   { current: text, tenX: text, hundredX: text, failureAtScale: text }
  scaleAnalysis Json?

  // ── AI INTERACTIONS LOG ────────────────────────────
  // Array of { phase, mode, userQuery, aiResponse, timestamp }
  // mode: 'validate' | 'guide' | 'teach'
  // Never queried independently — always loaded with the session.
  // Enables: showing learning journey, preventing repeat answers,
  // and analytics on which concepts users struggle with most.
  aiInteractions Json?

  // ── EVALUATION (final comprehensive AI assessment) ──
  // Set when status transitions to COMPLETED.
  // JSON: {
  //   dimensions: { requirementsCompleteness: 0-10, estimationSoundness: 0-10,
  //     apiDesignQuality: 0-10, dataModelCorrectness: 0-10,
  //     architectureCoherence: 0-10, deepDiveDepth: 0-10,
  //     tradeoffAwareness: 0-10, scenarioResilience: 0-10,
  //     scaleReadiness: 0-10, communicationClarity: 0-10 },
  //   overallScore: 0-10 (weighted average),
  //   criticalGaps: [string],
  //   strengths: [string],
  //   improvements: [string],
  //   industryComparison: string,
  //   readinessVerdict: string,
  //   suggestedNextSteps: [string]
  // }
  evaluation Json?

  // ── TIMING ─────────────────────────────────────────
  // Total seconds spent in this session (cumulative across resumes)
  totalTimeSpent Int @default(0)

  // Per-phase time breakdown: { [phaseId]: seconds }
  // Enables: "You spend 40% on requirements but 10% on trade-offs"
  phaseTimings Json?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  // ── Paired interview sessions (mode=INTERVIEW only) ──
  // A DesignSession in INTERVIEW mode is paired with one or more
  // InterviewSession rows (typically one — the active interview;
  // historical re-runs would create new InterviewSession rows).
  interviewSessions InterviewSession[]

  // ── Timestamps ─────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Indexes ────────────────────────────────────────
  // "My design sessions" — for the Design Studio history page
  @@index([userId, createdAt(sort: Desc)])
  // "My sessions for a specific problem" — for attempt comparison
  @@index([userId, problemId, createdAt(sort: Desc)])
  // "Team design sessions" — for team analytics
  @@index([teamId, createdAt(sort: Desc)])
  // Active sessions (for cleanup/monitoring)
  @@index([status, createdAt])
  // Filter by design type
  @@index([userId, designType, createdAt(sort: Desc)])
  @@map("design_sessions")
}

// ============================================================================
// DESIGN REFERENCE
// ============================================================================

/// Curated worked-example architecture for a design problem.
///
/// Rationale (Sweller — cognitive load, worked examples): novices benefit
/// from studying expert solutions AFTER attempting a problem themselves.
/// The client gates access to the reference until the learner has filled
/// ≥ 4 phases or entered validation — preserves retrieval practice and
/// avoids the premature-exposure failure mode where the reference
/// becomes a spoiler.
///
/// One problem can have multiple references (variant column) because
/// there's rarely one "right" SD/LLD answer — e.g. a URL shortener can
/// be a single-region sharded-KV OR a globally-distributed CRDT design,
/// both valid with different trade-offs. `variant` disambiguates them.
///
/// Curated by admins (authorId nullable so seeded references can ship
/// without a synthetic user). Version is bumped on meaningful edits for
/// future change-tracking; not currently surfaced to users.
model DesignReference {
  id String @id @default(cuid())

  // ── Problem linkage ────────────────────────────────
  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  // ── Classification ─────────────────────────────────
  designType DesignType
  difficulty Difficulty
  variant    String // e.g. "single-region-sharded-kv"
  title      String
  summary    String     @db.Text

  // ── Content (mirrors DesignSession shape) ──────────
  phases               Json // { [phaseId]: content }
  diagramData          String? @db.Text
  componentAnnotations Json? // [{ componentName, purpose, technology, notes }]
  dataFlowDescription  String? @db.Text

  // ── Pedagogy ───────────────────────────────────────
  // tradeoffs: [{ choice, alternative, reason }] — named alternatives
  // the reference did NOT take, to prevent "book says X is right"
  // framing.
  tradeoffs Json
  // sources: [{ label, url }] — papers, talks, blog posts the reference
  // draws from. Gives the learner a trail to go deeper.
  sources   Json

  // ── Authorship ─────────────────────────────────────
  // Nullable so seeded/curated references can ship without tying them
  // to a real user. Edits bump version so clients can detect change.
  authorId String?
  author   User?   @relation("DesignReferenceAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  version  Int     @default(1)

  // ── Timestamps ─────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Prevent duplicate variants per problem
  @@unique([problemId, variant])
  // Lookup "references for this problem of this type"
  @@index([problemId, designType])
  @@map("design_references")
}

