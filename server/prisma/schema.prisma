// ============================================================================
// FEEDBACK REPORT
// ============================================================================
/// User-submitted bug report, suggestion, or question.
///
/// DESIGN DECISIONS:
///
/// 1. teamId is nullable — works in both team and individual (personal) mode.
///    The member's current team context at time of submission is captured
///    so admin can understand the context without asking.
///
/// 2. severity is set by the submitter, not computed. This is intentional —
///    the person experiencing the issue knows the impact better than any
///    heuristic. Admin can override in adminNote.
///
/// 3. stepsToReproduce is separate from description. Bug reports need
///    reproducible steps; suggestions and questions do not. Keeping them
///    separate makes the form adapt per type and keeps data clean.
///
/// 4. On submit: DB write + email notification fire together.
///    Email is fire-and-forget (failure does not fail the submission).
///    Member always gets confirmation that their report was received.
model FeedbackReport {
  id String @id @default(cuid())

  // ── Report content ─────────────────────────────────
  type        FeedbackType     @default(BUG)
  title       String
  description String
  severity    FeedbackSeverity @default(MEDIUM)

  // ── Context ────────────────────────────────────────
  affectedArea     String?
  stepsToReproduce String?

  // ── Status tracking ────────────────────────────────
  status    FeedbackStatus @default(OPEN)
  adminNote String?

  // ── Submitter ──────────────────────────────────────
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Team context (nullable) ────────────────────────
  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  // ── Timestamps ─────────────────────────────────────
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  // ── Indexes ────────────────────────────────────────
  @@index([status, createdAt(sort: Desc)], map: "idx_feedback_status_created")
  @@index([userId, createdAt(sort: Desc)], map: "idx_feedback_user")
  @@index([teamId, createdAt(sort: Desc)], map: "idx_feedback_team")
  @@map("feedback_reports")
}

// ============================================================================
// SKILL PROFILE
// ============================================================================
/// Computed skill proficiency per user per skill.
///
/// DESIGN DECISIONS:
///
/// 1. Not team-scoped. Skills belong to the person, not the team context.
///    A user who demonstrates Dynamic Programming in one team has that skill
///    everywhere. This is architecturally different from Solutions.
///
/// 2. skillId is a string constant from skillTaxonomy.js, not a FK to a
///    Skill table. The taxonomy is static code — storing it in the DB adds
///    operational overhead with no query benefit.
///
/// 3. rawScore and decayedScore are stored separately.
///    rawScore = evidence-weighted proficiency before time decay.
///    decayedScore = what gets displayed to the user.
///    Storing both enables "you had 78 but it decayed to 61" messaging.
///
/// 4. isVerified = true only when a formal blind assessment was passed
///    with all three gates simultaneously (accuracy >= 80%, time within
///    1.5x expert benchmark, explanation quality >= 7/10).
///    This is the "definitely has this skill" claim.
///
/// Recomputed on:
///   - Solution submission with AI review
///   - Quiz completion
///   - Mock interview debrief
///   - Spaced repetition review
model SkillProfile {
  id String @id @default(cuid())

  // ── User (not team-scoped) ─────────────────────────
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Skill identity ─────────────────────────────────
  // String constant from skillTaxonomy.js
  skillId       String
  skillCategory String

  // ── Scores ─────────────────────────────────────────
  // Raw: evidence-weighted before Ebbinghaus decay
  // Decayed: rawScore × e^(-daysSinceEvidence / (stability × 10))
  rawScore     Float @default(0)
  decayedScore Float @default(0)

  // ── Dreyfus proficiency level ──────────────────────
  proficiencyLevel SkillProficiencyLevel @default(NOVICE)

  // ── Evidence quality ───────────────────────────────
  // Low evidenceCount = low confidence in the score
  evidenceCount Int @default(0)

  // ── Verification ───────────────────────────────────
  // isVerified = true only when blind assessment passed (all 3 gates)
  isVerified         Boolean @default(false)
  verifiedConfidence String? // 'HIGH' | 'MEDIUM'

  // ── Recency tracking ───────────────────────────────
  lastEvidenceAt DateTime?

  // ── Trajectory ─────────────────────────────────────
  // Computed from last 5 evidence points
  trend String? // 'improving' | 'stable' | 'declining'

  // ── Timestamps ─────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Constraints ────────────────────────────────────
  @@unique([userId, skillId])
  // ── Indexes ────────────────────────────────────────
  @@index([userId])
  @@index([userId, skillCategory])
  @@index([userId, isVerified])
  @@index([userId, decayedScore(sort: Desc)])
  @@map("skill_profiles")
}

// ============================================================================
// SKILL ASSESSMENT
// ============================================================================
/// A formal skill assessment session.
///
/// Three simultaneous pass gates — ALL must pass for PASSED status:
///   Gate 1: accuracy >= 80% on application problems
///   Gate 2: time within 1.5x expert benchmark
///   Gate 3: explanation quality >= 7/10 from AI review
///
/// Scientific basis for the 3-gate requirement:
///   Accuracy alone measures procedural knowledge.
///   Time gate measures fluency (Bloom, 1968 — automaticity required for transfer).
///   Explanation gate measures conceptual understanding (Karpicke & Blunt, 2011).
///   All three together measure what an interview actually demands.
///
/// attemptNumber determines verifiedConfidence on pass:
///   Attempt 1 → HIGH confidence
///   Attempt 2+ → MEDIUM confidence
model SkillAssessment {
  id String @id @default(cuid())

  // ── User ───────────────────────────────────────────
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Skill being assessed ───────────────────────────
  skillId       String
  skillCategory String

  // ── Session lifecycle ──────────────────────────────
  status        SkillAssessmentStatus @default(IN_PROGRESS)
  attemptNumber Int                   @default(1)

  // ── Gate 1: Accuracy (>= 80% required) ────────────
  accuracyScore  Float?
  accuracyPassed Boolean @default(false)

  // ── Gate 2: Time (within 1.5x expert benchmark) ───
  timeScore     Int? // actual seconds taken
  timeBenchmark Int? // expert benchmark seconds
  timePassed    Boolean @default(false)

  // ── Gate 3: Explanation quality (>= 7/10) ─────────
  explanationScore  Float?
  explanationPassed Boolean @default(false)

  // ── Overall ────────────────────────────────────────
  overallScore Float?
  aiFeedback   String?

  // ── Timing ─────────────────────────────────────────
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  timeSpentSeconds Int?

  // ── Timestamps ─────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ──────────────────────────────────────
  responses AssessmentResponse[]

  // ── Indexes ────────────────────────────────────────
  @@index([userId])
  @@index([userId, skillId])
  @@index([userId, status])
  @@map("skill_assessments")
}

// ============================================================================
// ASSESSMENT RESPONSE
// ============================================================================
/// A single problem response within a skill assessment session.
///
/// Deliberately separate from the Solution model.
/// Assessment responses are:
///   - Isolated from the practice pool
///   - Never shown as "teammate solutions"
///   - Not indexed for RAG retrieval
///   - Evaluated against assessment-specific criteria
model AssessmentResponse {
  id String @id @default(cuid())

  // ── Assessment reference ───────────────────────────
  assessmentId String
  assessment   SkillAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  // ── Problem reference ──────────────────────────────
  // Only problems with isAssessmentOnly=true should appear here
  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Restrict)

  // ── Question type ──────────────────────────────────
  // 'recognition'  = MCQ identifying correct approach
  // 'application'  = write code solving the problem
  // 'explanation'  = explain mechanism, trade-offs, real-world usage
  questionType String

  // ── Response content ───────────────────────────────
  answer String?

  // ── Evaluation ─────────────────────────────────────
  isPassed   Boolean @default(false)
  aiScore    Float?
  aiFeedback String?

  // ── Timing ─────────────────────────────────────────
  timeSpentSeconds Int?

  // ── Timestamps ─────────────────────────────────────
  createdAt DateTime @default(now())

  // ── Indexes ────────────────────────────────────────
  @@index([assessmentId])
  @@map("assessment_responses")
}

// ============================================================================
// COMPETITION ENTRY (FUTURE)
// ============================================================================

/// A user's participation in a competition.
model CompetitionEntry {
  id String @id @default(cuid())

  // ── Competition ────────────────────────────────────
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  // ── Participant ────────────────────────────────────
  userId String

  // ── Results ────────────────────────────────────────
  score       Int   @default(0)
  rank        Int?
  submissions Json?

  // ── Timing ─────────────────────────────────────────
  startedAt   DateTime?
  completedAt DateTime?

  // ── Timestamps ─────────────────────────────────────
  createdAt DateTime @default(now())

  // ── Constraints ────────────────────────────────────
  @@unique([userId, competitionId])
  // ── Indexes ────────────────────────────────────────
  @@index([competitionId, score(sort: Desc)])
  @@map("competition_entries")
}

// ============================================================================
// USAGE TRACKING — per-AI-call telemetry
// ============================================================================
//
// One row per ai.service.js call (success OR failure). Mirrors the
// usage event payload emitted by aiComplete / aiStream so a 1:1 writer
// can persist with no transformation. Used for:
//
//   1. Per-surface fallback rate (catches prompt regression)
//   2. p99 latency by surface (catches model slowness)
//   3. Per-team daily token spend (cost attribution; future billing)
//
// Append-only — pruned by a daily cron beyond 90 days. Both userId
// and teamId are nullable to handle anonymous/unscoped surfaces
// (e.g. system-init AI calls before a user is identified).
// ============================================================================
model UsageTracking {
  id String @id @default(cuid())

  // Optional ownership — null for unscoped calls.
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  // What surface emitted this event.
  surface String

  // Models the request/response actually used. modelRequested may
  // differ from modelUsed when the fallback chain in ai.service kicked in.
  modelRequested String
  modelUsed      String

  // Token + latency telemetry from the OpenAI response.
  promptTokens     Int @default(0)
  completionTokens Int @default(0)
  totalTokens      Int @default(0)
  latencyMs        Int @default(0)

  // Outcome flags.
  usedFallback Boolean @default(false)
  cached       Boolean @default(false)
  errorCode    String? // null on success; AIError code on failure

  // Streaming calls (aiStream) emit a single open event with stream=true.
  // Useful for separating chat-style traffic from one-shot completions
  // when computing latency p99s.
  streamCall Boolean @default(false)

  createdAt DateTime @default(now())

  // Per-team daily spend rollups + general "what happened today" queries.
  @@index([teamId, createdAt])
  // Per-surface fallback-rate / latency p99 queries.
  @@index([surface, createdAt])
  // Cron prune by createdAt < cutoff.
  @@index([createdAt])
  @@map("usage_tracking")
}

// ============================================================================
// TEAM TEACHING SESSIONS — peer-to-peer knowledge sharing within a team
// ============================================================================
//
// Members schedule + run sessions where one member teaches a topic. Peers
// rate the teacher; flags surface to admins; AI summarizes the teacher's
// notes + generates a quiz + scores topic-coverage. The host's
// participation feeds the new D7 "Teaching Contributions" dimension on
// the Intelligence Report (activates after ≥1 session hosted + ≥3 peer
// ratings, conservative ~10% weight).
//
// v1 scope: external meeting link (Zoom/Meet/etc.) + manually-typed
// markdown notes + a thin in-app live room (presence + Q&A only over the
// existing WebSocket — no recording, no transcript). Recording +
// transcripts deferred to v2 pending real-usage data.
//
// Lifecycle: SCHEDULED → LIVE → COMPLETED. CANCELLED is terminal from
// any non-COMPLETED state. notifiedStartingSoonAt + notifiedLiveNowAt
// give the cron CAS-style idempotency so a multi-replica deploy doesn't
// double-broadcast the same session transition.
// ============================================================================
enum TeachingStatus {
  DRAFT
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

enum TeachingFlagStatus {
  OPEN
  REVIEWED
  DISMISSED
}

model TeachingSession {
  id String @id @default(cuid())

  // ── Ownership (team-scoped) ────────────────────────
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  hostId String
  host   User   @relation("TeachingHost", fields: [hostId], references: [id], onDelete: Cascade)

  // ── Core ───────────────────────────────────────────
  title               String
  topic               String
  description         String?
  externalMeetingLink String?
  capacity            Int     @default(20)

  // ── Lifecycle ──────────────────────────────────────
  status      TeachingStatus @default(SCHEDULED)
  scheduledAt DateTime
  startedAt   DateTime?
  endedAt     DateTime?

  // CAS idempotency for the 60s scheduler — flipped null → date once.
  notifiedStartingSoonAt DateTime?
  notifiedLiveNowAt      DateTime?

  // ── Notes (markdown, post-session) ─────────────────
  notes String?

  // ── AI artifacts (filled async after submitNotes) ──
  // summary       — teachingSummaryPrompt output (tldr + key takeaways)
  // quiz          — teachingQuizPrompt output (3-5 review questions)
  // topicCoverage — teachingTopicCoveragePrompt output (FULL/PARTIAL/OFF_TOPIC)
  summary       Json?
  quiz          Json?
  topicCoverage Json?
  aiGeneratedAt DateTime?

  // ── Moderation ─────────────────────────────────────
  flagCount Int @default(0)

  // ── Soft delete ────────────────────────────────────
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendees TeachingAttendee[]
  ratings   TeachingRating[]
  flags     TeachingFlag[]

  // Hot path 1: upcoming sessions for this team (calendar list).
  @@index([teamId, status, scheduledAt])
  // Hot path 2: past sessions for D7 + leaderboard rollups.
  @@index([teamId, status, endedAt(sort: Desc)])
  // Cron poll: any session crossing the 5-min / start window.
  @@index([status, scheduledAt])
  // Host page — "my sessions".
  @@index([hostId, status, scheduledAt])
  @@map("teaching_sessions")
}

model TeachingAttendee {
  id String @id @default(cuid())

  sessionId String
  session   TeachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation("TeachingAttendee", fields: [userId], references: [id], onDelete: Cascade)

  joinedAt   DateTime  @default(now())
  leftAt     DateTime?
  durationMs Int?

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
  @@map("teaching_attendees")
}

model TeachingRating {
  id String @id @default(cuid())

  sessionId String
  session   TeachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  raterId   String
  rater     User            @relation("TeachingRater", fields: [raterId], references: [id], onDelete: Cascade)

  rating      Int // 1-5
  comment     String?
  peerLearned Boolean @default(false) // "I learned something" — feeds D7 score

  createdAt DateTime @default(now())

  @@unique([sessionId, raterId])
  @@index([sessionId])
  @@map("teaching_ratings")
}

model TeachingFlag {
  id String @id @default(cuid())

  sessionId  String
  session    TeachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  reporterId String
  reporter   User            @relation("TeachingFlagger", fields: [reporterId], references: [id], onDelete: Cascade)

  reason String
  status TeachingFlagStatus @default(OPEN)

  resolvedById   String?
  resolvedAt     DateTime?
  resolutionNote String?

  createdAt DateTime @default(now())

  @@index([status, createdAt])
  @@index([sessionId])
  @@map("teaching_flags")
}

// ============================================================================
// NOTES — personal markdown workspace
// ============================================================================
//
// Notes are user-scoped (no teamId). They survive team switches and are
// never visible to other users. Routes use `authenticate` only — no
// `requireTeamContext` — so a team-status bug can't break notes access.
//
// `linkedEntity*` columns let a note attach to a Problem / interview /
// design / teaching session. `linkedEntityTitle` is a snapshot so a
// dangling link (entity moved out of view after a team switch or
// deletion) still renders gracefully.
//
// `embedding` populated by a fire-and-forget background job after every
// content write. Used for "related notes" + cross-table similarity
// against Problem.embedding for "suggest links to your problems".
// ============================================================================

enum NoteEntityType {
  PROBLEM
  INTERVIEW_SESSION
  DESIGN_SESSION
  TEACHING_SESSION
  CUSTOM
}

model Note {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title           String
  contentMarkdown String  @db.Text
  tags            String[]

  // Optional entity attachment — null = standalone scratchpad.
  linkedEntityType  NoteEntityType?
  linkedEntityId    String?
  linkedEntityTitle String?

  // AI-generated artifacts. `summary` shape locked by validateNoteSummary.
  summary            Json?
  summaryGeneratedAt DateTime?
  suggestedTags      String[]

  // pgvector(1536) — actual column + HNSW index live in the migration SQL.
  embedding Unsupported("vector(1536)")?

  pinned     Boolean   @default(false)
  archivedAt DateTime?

  // True when this note was generated by the system (today: from an AI
  // Solution Review). UI uses it to distinguish auto-notes; the auto-note
  // pipeline uses it as the safety flag — only auto-generated notes are
  // eligible for system-driven update on re-analysis. User-edited notes
  // are never overwritten.
  autoGenerated Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  flashcards Flashcard[]

  @@index([userId, archivedAt, pinned, updatedAt])
  @@index([userId, linkedEntityType, linkedEntityId])
  @@index([userId, archivedAt])
  @@index([embedding], map: "idx_notes_embedding_hnsw")
  @@map("notes")
}

// ============================================================================
// FLASHCARDS — SM-2 cards generated from notes (or manual)
// ============================================================================
//
// Mirrors the SM-2 columns on Solution. Lives in its own table so the
// existing Solution review path is byte-identical; the combined queue is
// merged client-side.
//
// noteId nullable so manually-created cards (no parent note) work.
// onDelete: SetNull keeps the card alive if the source note is deleted.
// ============================================================================

model Flashcard {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  noteId String?
  note   Note?   @relation(fields: [noteId], references: [id], onDelete: SetNull)

  front String
  back  String  @db.Text
  tags  String[]

  // ── SM-2 state (mirrors Solution) ──────────────────
  sm2EasinessFactor Float    @default(2.5)
  sm2Interval       Int      @default(1)
  sm2Repetitions    Int      @default(0)
  lapseCount        Int      @default(0)
  nextReviewDate    DateTime
  reviewCount       Int      @default(0)
  lastReviewedAt    DateTime?
  reviewDates       Json     @default("[]")

  aiGenerated Boolean   @default(false)
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, archivedAt, nextReviewDate])
  @@index([userId, noteId])
  @@map("flashcards")
}
