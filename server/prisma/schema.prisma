  // ── Who generated it ───────────────────────────────
  generatedById String

  // ── Analysis content ───────────────────────────────
  // Full AI response: healthScore, executiveSummary, insights,
  // trends, recommendations, risks
  content Json

  // ── Metrics snapshot ───────────────────────────────
  // The raw metrics that were sent to AI for analysis.
  // Stored so we can compare what the AI was looking at.
  metricsSnapshot Json?

  // ── Config ─────────────────────────────────────────
